# Copy to keystore.env (gitignored) or export before bundleRelease
PLAY_KEYSTORE=../horserace-release.jks
PLAY_KEY_ALIAS=horserace
PLAY_KEYSTORE_PASSWORD=
PLAY_KEY_PASSWORD=

# Generate keystore (once):
# keytool -genkeypair -v -keystore horserace-release.jks -alias horserace -keyalg RSA -keysize 2048 -validity 10000

# Passwords are stored locally in KEYSTORE.local.md (gitignored) after generation.
