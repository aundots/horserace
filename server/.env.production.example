PORT=4000
APP_NAME=horserace
SESSION_SECRET=change-to-long-random-secret
DEV_LOGIN=false

MTLS_CERT_PATH=cert/client-cert.pem
MTLS_KEY_PATH=cert/client-key.pem

PLAY_DEMO=false

# Play Store IARC 체험 로그인 (/auth/demo-login)
# PLAY_DEMO=true

# 친구 방 — Vercel/서버리스에서 인스턴스 간 공유 (권장)
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxx
# (Vercel KV 호환: KV_REST_API_URL / KV_REST_API_TOKEN)

# --- Play Store / IARC internal test ---
# Enable POST /auth/demo-login for the GitHub Pages Play build (VITE_PLAY_STORE).
# Required on the API host before reviewers can use "게스트 체험하기".
# PLAY_DEMO=true
