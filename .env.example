VITE_API_BASE_URL=http://localhost:4000

# Production: omit or set false. Dev login UI is hidden in production builds.
# VITE_DEV_LOGIN=false

# Local dev (vite dev server): set true to show dev login button
VITE_DEV_LOGIN=true

# Optional: dev user key for dev login (must match server DEV_USER_KEY)
# VITE_DEV_USER_KEY=10001

# Toss Apps-in-Toss rewarded ad group ID (replace with production ID before release)
VITE_AD_GROUP_ID=ait-ad-test-rewarded-id

# Allow mock ad claims in non-Toss browser builds (vite build preview). Default: only vite dev.
# VITE_AD_DEV_MOCK=true
